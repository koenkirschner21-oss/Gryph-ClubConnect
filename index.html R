                    <div class="feature-row">✓ Priority support</div>
                </div>
                <button class="btn btn-primary">Start 14-Day Free Trial</button>
            </div>
            <div class="pricing-card">
                <div class="pricing-label gold">INSTITUTIONAL</div>
                <div class="pricing-price">Custom</div>
                <div class="pricing-period">University-wide licensing</div>
                <div class="pricing-features">
                    <div class="feature-row">✓ All clubs on one license</div>
                    <div class="feature-row">✓ Central admin oversight</div>
